[Unit]
Description=Sweetbomb Admin Frontend (Vite) - SWNFP
After=network.target

[Service]
Type=simple
User=jetson
WorkingDirectory=/home/jetson/sweetbomb/ui/admin-frontend
ExecStart=/usr/bin/npm run dev
Restart=always
RestartSec=3
Environment=NODE_ENV=development

[Install]
WantedBy=multi-user.target