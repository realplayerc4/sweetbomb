{
  "mcpServers": {
    "playwrighter": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "chrome": {
      "command": "npx",
      "args": ["-y", "chromecp"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp"]
    },
    "streamable-mcp-server": {
      "type": "streamable-http",
      "url": "http://127.0.0.1:12306/mcp"
    }
  }
}
